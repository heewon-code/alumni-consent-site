name: Keep Alive

on:
  schedule:
    - cron: '*/5 * * * *'
  workflow_dispatch:

jobs:
  ping:
    runs-on: ubuntu-latest
    steps:
      - name: Ping server
        run: |
          STATUS=$(curl -s -o /dev/null -w "%{http_code}" https://alumni-consent-site-1.onrender.com)
          echo "HTTP status: $STATUS"
